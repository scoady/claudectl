          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "" },
          "type": "json",
          "source": "url",
          "url": "http://host.docker.internal:4040/api/metrics/tasks",
          "url_options": { "method": "GET" },
          "format": "timeseries",
          "root_selector": "",
          "columns": [
            { "selector": "time", "text": "time", "type": "timestamp" },
            { "selector": "started", "text": "started", "type": "number" },
            { "selector": "completed", "text": "completed", "type": "number" },
            { "selector": "failed", "text": "failed", "type": "number" }
          ]
        }
