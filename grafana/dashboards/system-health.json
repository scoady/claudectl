          { "matcher": { "id": "byName", "options": "cumulative_cost" }, "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "color", "value": { "fixedColor": "#34d399", "mode": "fixed" } }, { "id": "custom.cellOptions", "value": { "type": "color-text" } }] },
